<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
  <defs>
    <!-- 左侧月牙渐变：青色到紫色 -->
    <linearGradient id="leftGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#00E5CC"/>
      <stop offset="100%" stop-color="#C850C0"/>
    </linearGradient>
    <!-- 右侧月牙渐变：粉色到品红 -->
    <linearGradient id="rightGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FF6B9D"/>
      <stop offset="100%" stop-color="#C850C0"/>
    </linearGradient>
  </defs>
  
  <!-- 左侧月牙 -->
  <path 
    d="M32 4 
       C16.5 4 4 16.5 4 32 
       C4 40 7 47.5 12.5 53 
       C8 47 6 40 6 33 
       C6 19 17 8 32 8 
       C32 6 32 4 32 4Z"
    fill="url(#leftGrad)"
  />
  
  <!-- 右侧月牙 -->
  <path 
    d="M32 4 
       C47.5 4 60 16.5 60 32 
       C60 40 57 47.5 51.5 53 
       C56 47 58 40 58 33 
       C58 19 47 8 32 8 
       C32 6 32 4 32 4Z"
    fill="url(#rightGrad)"
  />
  
  <!-- 底部连接弧 - 左 -->
  <path 
    d="M4 32 
       C4 47.5 16.5 60 32 60 
       C24 60 12 53 8 40
       C5 36 4 32 4 32Z"
    fill="url(#leftGrad)"
    opacity="0.9"
  />
  
  <!-- 底部连接弧 - 右 -->
  <path 
    d="M60 32 
       C60 47.5 47.5 60 32 60 
       C40 60 52 53 56 40
       C59 36 60 32 60 32Z"
    fill="url(#rightGrad)"
    opacity="0.9"
  />
  
  <!-- 中央四角星 -->
  <path 
    d="M32 20 
       L33.5 28.5 
       L42 30 
       L33.5 31.5 
       L32 40 
       L30.5 31.5 
       L22 30 
       L30.5 28.5 Z"
    fill="white"
  />
</svg>
